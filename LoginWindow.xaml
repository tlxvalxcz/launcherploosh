<?xml version="1.0" encoding="utf-8"?>
<ui:FluentWindow
    x:Class="PlooshLauncher.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Height="640" Width="480"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="None"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Title="Ploosh Launcher">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1f2122" Offset="0"/>
                <GradientStop Color="#1d1e1f" Offset="0.5"/>
                <GradientStop Color="#3b054e05" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ui:TitleBar Title="" Background="Transparent" Height="40" VerticalAlignment="Top"/>

        <!-- ===== SPLASH (shown first) ===== -->
        <StackPanel x:Name="splashPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40,0">
            <Border Width="64" Height="64" CornerRadius="14" Margin="0,0,0,18" HorizontalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#28c936" Offset="0"/>
                        <GradientStop Color="#10801b" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="P" Foreground="#000" FontWeight="Bold" FontSize="30"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="PLOOSH LAUNCHER" Foreground="White" FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Sign in to continue" Foreground="#a5a5a5" FontSize="12.5"
                       FontWeight="Medium" HorizontalAlignment="Center" Margin="0,4,0,28"/>

            <Button x:Name="discordButton" Click="discordClick" Cursor="Hand"
                    HorizontalAlignment="Stretch" Height="46" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#5865F2" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4752c4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#36485c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <Path Fill="White" Stretch="Uniform" Width="20" Height="16" Margin="0,0,10,0"
                          Data="M19.27 5.33C17.94 4.71 16.5 4.26 15 4a.09.09 0 0 0-.07.03c-.18.33-.39.76-.53 1.09a16.09 16.09 0 0 0-4.8 0c-.14-.34-.36-.76-.54-1.09c-.01-.02-.04-.03-.07-.03c-1.5.26-2.93.71-4.27 1.33c-.01 0-.02.01-.03.02c-2.72 4.07-3.47 8.03-3.1 11.95c0 .02.01.04.03.05c1.8 1.32 3.53 2.12 5.24 2.65c.03.01.06 0 .07-.02c.4-.55.76-1.13 1.07-1.74c.02-.04 0-.08-.04-.09c-.57-.22-1.11-.48-1.64-.78c-.04-.02-.04-.08-.01-.11c.11-.08.22-.17.33-.25c.02-.02.05-.02.07-.01c3.44 1.57 7.15 1.57 10.55 0c.02-.01.05-.01.07.01c.11.09.22.17.33.26c.04.03.04.09-.01.11c-.52.31-1.07.56-1.64.78c-.04.01-.05.06-.04.09c.32.61.68 1.19 1.07 1.74c.03.01.06.02.09.01c1.72-.53 3.45-1.33 5.25-2.65c.02-.01.03-.03.03-.05c.44-4.53-.73-8.46-3.1-11.95c-.01-.01-.02-.02-.04-.02zM8.52 14.91c-1.03 0-1.89-.95-1.89-2.12s.84-2.12 1.89-2.12c1.06 0 1.9.96 1.89 2.12c0 1.17-.84 2.12-1.89 2.12zm6.97 0c-1.03 0-1.89-.95-1.89-2.12s.84-2.12 1.89-2.12c1.06 0 1.9.96 1.89 2.12c0 1.17-.83 2.12-1.89 2.12z"/>
                    <TextBlock Text="Continue with Discord" Foreground="White" FontSize="14"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <TextBlock x:Name="statusText" Text="" Foreground="#a5a5a5" FontSize="12"
                       FontWeight="Medium" HorizontalAlignment="Center" Margin="0,16,0,0"
                       TextWrapping="Wrap" TextAlignment="Center"/>
        </StackPanel>

        <!-- ===== IN-APP BROWSER (hidden until sign-in) ===== -->
        <wv2:WebView2 x:Name="webView" Visibility="Collapsed" Margin="0,40,0,0"
                      DefaultBackgroundColor="#1f2122"/>
    </Grid>
</ui:FluentWindow>