<?xml version="1.0" encoding="utf-8"?>
<ui:FluentWindow
    x:Class="PlooshLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:PlooshLauncher"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Height="640"
    Width="1000"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="None"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    MinHeight="560"
    MinWidth="860">

    <Window.Resources>
        <!-- Retrac palette -->
        <SolidColorBrush x:Key="ActiveBrush" Color="#ffffff"/>
        <SolidColorBrush x:Key="AlmostActiveBrush" Color="#cdd5e6"/>
        <SolidColorBrush x:Key="SemiActiveBrush" Color="#a5a5a5"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#28c936"/>
        <SolidColorBrush x:Key="GoldBrush" Color="#f0c419"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#18191a"/>
        <SolidColorBrush x:Key="CardBrush" Color="#262829"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#0dffffff"/>

        <!-- Card look -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <!-- Section header (Play Retrac / News & Updates) -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SemiActiveBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2,22,0,12"/>
        </Style>

        <!-- Stat row label / value -->
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SemiActiveBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ActiveBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Sidebar nav button -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SemiActiveBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="6,1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#14ffffff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action (Download Now) — blue/purple gradient -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="16,11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#3b6fe0" Offset="0"/>
                                    <GradientStop Color="#6a4bd0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#4a7ef0" Offset="0"/>
                                            <GradientStop Color="#7a5be0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#36485c"/>
                                <Setter Property="Foreground" Value="#bbffffff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary action (Claim reward) — flat gray -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource AlmostActiveBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="16,11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#14ffffff" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22ffffff"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#0affffff"/>
                                <Setter Property="Foreground" Value="#66ffffff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Whole-window gradient backdrop -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1f2122" Offset="0"/>
                <GradientStop Color="#1d1e1f" Offset="0.4"/>
                <GradientStop Color="#3b054e05" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="210"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ============ LEFT SIDEBAR ============ -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="8,8,8,0">
                    <!-- Home (active) -->
                    <Button Style="{StaticResource NavButton}" Background="#14ffffff" Foreground="White">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" FontSize="15"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Home" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" FontSize="15"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Library" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D9;" FontSize="15"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Matches" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="#22ffffff" CornerRadius="9" Padding="7,2">
                                <TextBlock Text="91" Foreground="{StaticResource AlmostActiveBrush}"
                                           FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE735;" FontSize="15"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Tournaments" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A1;" FontSize="15"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Leaderboards" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource NavButton}" Foreground="{StaticResource GoldBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEB51;" FontSize="15"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Donate" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Bottom nav -->
                <StackPanel Grid.Row="1" Margin="8,8,8,12">
                    <Button Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE897;" FontSize="15"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Need Help?" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="15"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ TITLE BAR (center + right) ============ -->
        <ui:TitleBar Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                     Title="" Background="Transparent" Height="44">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="PLOOSH" Foreground="{StaticResource ActiveBrush}"
                               FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="  build 1.0.0" Foreground="{StaticResource SemiActiveBrush}"
                               FontSize="12" FontWeight="Medium" VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- ============ CENTER CONTENT ============ -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      Padding="24,8,24,24">
            <StackPanel>

                <!-- Top row: welcome + statistics -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Welcome card -->
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="92"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource ActiveBrush}">
                                    <Run Text="Welcome back, "/><Run x:Name="welcomeNameText" Text="wsg4700" FontWeight="Bold"/><Run Text="."/>
                                </TextBlock>
                                <TextBlock Foreground="{StaticResource SemiActiveBrush}" FontSize="12"
                                           FontWeight="Medium" Margin="0,3,0,16">
                                    <Run Text="There are currently "/><Run x:Name="playersOnlineText" Text="4,184" Foreground="{StaticResource AlmostActiveBrush}"/><Run Text=" players online."/>
                                </TextBlock>

                                <Grid Margin="0,0,0,7">
                                    <TextBlock Text="V-Bucks" Style="{StaticResource StatLabel}"/>
                                    <TextBlock x:Name="vBucksText" Text="0" Style="{StaticResource StatValue}"/>
                                </Grid>
                                <Grid Margin="0,0,0,7">
                                    <TextBlock Text="Season Level" Style="{StaticResource StatLabel}"/>
                                    <TextBlock x:Name="seasonLevelText" Text="0" Style="{StaticResource StatValue}"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Arena Hype" Style="{StaticResource StatLabel}"/>
                                    <TextBlock x:Name="arenaHypeText" Text="0" Style="{StaticResource StatValue}"/>
                                </Grid>
                            </StackPanel>

                            <!-- Character art placeholder (swap for an Image later) -->
                            <Border Grid.Column="2" CornerRadius="6">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#6a2bd0" Offset="0"/>
                                        <GradientStop Color="#d02b8a" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Statistics card -->
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Your Statistics" Foreground="{StaticResource ActiveBrush}"
                                       FontSize="14" FontWeight="SemiBold" Margin="0,0,0,14"/>
                            <Grid Margin="0,0,0,7">
                                <TextBlock Text="Eliminations" Style="{StaticResource StatLabel}"/>
                                <TextBlock x:Name="killsText" Text="0" Style="{StaticResource StatValue}"/>
                            </Grid>
                            <Grid Margin="0,0,0,7">
                                <TextBlock Text="Victory Royales" Style="{StaticResource StatLabel}"/>
                                <TextBlock x:Name="winsText" Text="0" Style="{StaticResource StatValue}"/>
                            </Grid>
                            <Grid Margin="0,0,0,7">
                                <TextBlock Text="Matches Played" Style="{StaticResource StatLabel}"/>
                                <TextBlock x:Name="matchesText" Text="0" Style="{StaticResource StatValue}"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Time Alive" Style="{StaticResource StatLabel}"/>
                                <TextBlock x:Name="timeText" Text="0h, 0m, 0s" Style="{StaticResource StatValue}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Play section -->
                <TextBlock Text="Play Ploosh" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Download card -->
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Latest Build" Foreground="{StaticResource ActiveBrush}"
                                       FontSize="18" FontWeight="Bold"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource SemiActiveBrush}"
                                       FontSize="12.5" FontWeight="Medium" Margin="0,8,0,18"
                                       Text="Grab the newest release and jump straight in. One click, fully patched, ready to run."/>
                            <Button Style="{StaticResource PrimaryButton}" Content="Download Now"
                                    Click="downloadClick"/>
                        </StackPanel>
                    </Border>

                    <!-- Claim reward card -->
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Looking for more?" Foreground="{StaticResource ActiveBrush}"
                                       FontSize="18" FontWeight="Bold"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource SemiActiveBrush}"
                                       FontSize="12.5" FontWeight="Medium" Margin="0,8,0,18"
                                       Text="Receive a gift package of V-Bucks every hour, for completely free! All you have to do is complete a simple offer from our sponsors."/>
                            <Button Style="{StaticResource SecondaryButton}" Content="Claim your reward now!"
                                    Click="claimClick"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- News & Updates -->
                <TextBlock Text="News &amp; Updates" Style="{StaticResource SectionHeader}"/>
                <StackPanel x:Name="newsList">

                    <!-- Placeholder announcement — copy this Border to add more -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,10" Cursor="Hand">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#28c936" Offset="0"/>
                                        <GradientStop Color="#10801b" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="test announcement" Foreground="{StaticResource ActiveBrush}"
                                               FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="  written by admin" Foreground="{StaticResource SemiActiveBrush}"
                                               FontSize="12" FontStyle="Italic" FontWeight="Medium"
                                               VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                </StackPanel>
                                <TextBlock Text="this is a test" Foreground="{StaticResource SemiActiveBrush}"
                                           FontSize="12.5" FontWeight="Medium" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Column="3" FontFamily="Segoe MDL2 Assets" Text="&#xE72A;"
                                       Foreground="{StaticResource SemiActiveBrush}" FontSize="16"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ============ RIGHT FRIENDS RAIL ============ -->
        <Border Grid.Row="1" Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1,0,0,0"
                Padding="14,14,14,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,12">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource GreenBrush}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="FRIENDS" Foreground="{StaticResource SemiActiveBrush}"
                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Bound in code-behind. Edit friends.txt (next to the .exe) to update. -->
                <ItemsControl x:Name="friendsList" Grid.Row="1">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#0affffff" CornerRadius="6" Padding="10,9" Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource GreenBrush}"
                                             VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource AlmostActiveBrush}"
                                               FontSize="13" FontWeight="Medium" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>